# ── Bitbucket authentication (pick ONE method) ───────────────────────────────
#
# Method A — Repository / Project / Workspace Access Token (recommended)
#   Bitbucket → Repo settings → Access tokens → Create. Scope: "Repository read".
#   Clone is done as  https://x-token-auth:<TOKEN>@bitbucket.org/<ws>/<repo>.git
BITBUCKET_TOKEN=

# Method B — App Password (legacy, being deprecated)
#   Bitbucket → Personal settings → App passwords → Create. Permission: "Repositories: Read".
BITBUCKET_USERNAME=
BITBUCKET_APP_PASSWORD=

# Method C — Atlassian API token (email + token)
#   id.atlassian.com → Security → API tokens.
BITBUCKET_EMAIL=
BITBUCKET_API_TOKEN=
